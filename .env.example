# 复制为 .env 后填写（勿将 .env 提交到版本库）

APP_ENV=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@127.0.0.1:5432/DBNAME

JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# 站内通知实时推送：Redis Pub/Sub + Stream（多 Worker 下 SSE 可收到推送）；不配则仅单进程内实时
# REDIS_URL=redis://127.0.0.1:6379/0

# DeepSeek（OpenAI 兼容 HTTP API，仅服务端使用）
# 文档见 docs/ai问答需求/DEV_PLAN.md
OPENAI_API_KEY=sk-c9989337b54f482eb2c53bbb79a6a6b4
OPENAI_API_BASE=https://api.deepseek.com
AI_CHAT_MODEL=deepseek-chat
# 可选：覆盖知识库目录（默认 <项目根>/docs/knowledge-base，见该目录 README）
# AI_KNOWLEDGE_DIR=

# 文档中心上传目录（默认 <项目根>/static/help_documents，并由 /static/help-documents 对外提供静态访问）
# HELP_DOCS_UPLOAD_DIR=
# 静态 URL 路径前缀（须与代码中 mount 一致，默认 /static/help-documents）
# HELP_DOCS_STATIC_MOUNT_PATH=
